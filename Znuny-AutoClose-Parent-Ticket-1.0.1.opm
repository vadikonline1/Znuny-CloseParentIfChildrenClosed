<?xml version="1.0" encoding="utf-8" ?>
<otrs_package version="1.1">
    <Name>Znuny-AutoClose-Parent-Ticket</Name>
    <Version>1.0.1</Version>
    <Vendor>vadikonline1</Vendor>
    <URL>https://github.com/vadikonline1/Znuny-AutoClose-Parent-Ticket</URL>
    <License>GNU GENERAL PUBLIC LICENSE Version 3, 29 June 2007</License>
    <ChangeLog Date="2024-04-30 00:00:00" Version="1.0.0">Initial release.</ChangeLog>
    <ChangeLog Date="2024-04-30 00:00:00" Version="1.0.1">Fixed LinkList parsing, added configurable states, added automatic article creation.</ChangeLog>
    <Description Lang="en">Automatically closes parent ticket when all child tickets are in a closed state. Adds an internal note to the parent ticket with the list of closed children.</Description>
    <Framework>7.0.x</Framework>
    <Framework>7.1.x</Framework>
    <Framework>7.2.x</Framework>
    <Framework>7.3.x</Framework>
    <Framework>7.4.x</Framework>
    <Framework>7.5.x</Framework>
    <IntroInstall Lang="en" Title="Install Information" Type="pre">
        &lt;br/&gt;
        &lt;b&gt;WELCOME&lt;/b&gt;
        &lt;br/&gt;
        &lt;br/&gt;
        You are about to install Znuny-AutoClose-Parent-Ticket.&lt;br/&gt;
        &lt;br/&gt;
        &lt;b&gt;What this package does:&lt;/b&gt;&lt;br/&gt;
        - When a child ticket is closed, checks if all children of the parent are in a closed state&lt;br/&gt;
        - If all children are in a closed state, automatically closes the parent ticket&lt;br/&gt;
        - Adds an internal note to the parent ticket with the list of closed children&lt;br/&gt;
        &lt;br/&gt;
        &lt;b&gt;Configuration (SysConfig):&lt;/b&gt;&lt;br/&gt;
        - AutoCloseParentTicket::ParentCloseState - State for parent ticket (default: closed successful)&lt;br/&gt;
        - AutoCloseParentTicket::ChildClosedStates - Comma-separated list of child closed states (default: closed successful,closed unsuccessful)&lt;br/&gt;
        &lt;br/&gt;
        ((enjoy))&lt;br/&gt;
        &lt;br/&gt;
    </IntroInstall>
    <IntroUpgrade Lang="en" Title="Upgrade Information" Type="pre">
        &lt;br/&gt;
        &lt;b&gt;Upgrade Information&lt;/b&gt;
        &lt;br/&gt;
        &lt;br/&gt;
        Clear the Znuny cache after upgrade:&lt;br/&gt;
        &lt;tt&gt;bin/znuny.Console.pl Maint::Cache::Delete&lt;/tt&gt;
        &lt;br/&gt;
    </IntroUpgrade>
    <BuildDate>2026-04-30 11:38:07</BuildDate>
    <BuildHost>znuny.vp.intranet.paypoint.md</BuildHost>
    <Filelist>
        <File Location="Kernel/Config/Files/XML/ZZAutoCloseParentTicket.xml" Permission="644" Encode="Base64"></File>
        <File Location="Kernel/System/Ticket/Event/AutoCloseParentTicket.pm" Permission="644" Encode="Base64"></File>
    </Filelist>
</otrs_package>